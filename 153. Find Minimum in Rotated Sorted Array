class Solution {
    public int findMin(int[] nums) {
        int min = 99999;
        int left = 0;
        int right = nums.length - 1;

        while(left <= right){
            int mid = left + (right - left) / 2;
            min = Math.min(nums[mid],min);

            if(nums[left] <= nums[mid]){
                 if(nums[mid] >= nums[right]){
                    left = mid + 1;
                    
                }else{
                    right = mid - 1;
                 
                }
            }else{
                if(nums[mid] <= nums[left]){
                    right = mid - 1;
          
                }else{
                    left = mid + 1;
                    
                }

            }
           
        }
        return min;
    }
}
