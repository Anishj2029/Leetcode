class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int n = nums.size();
        int max = -99999;
        int sum = 0;
        int i = 0;
        int j = i;
        int oldsum = 0;

        while(j < n){
            sum = sum + nums[j];

            if (sum < nums[j]){
               sum = nums[j];
            }
            if(max < sum){
                max = sum;
            }
            j++;
        }
        return max;
    }
};
