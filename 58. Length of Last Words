class Solution {
    public int lengthOfLastWord(String s) {
        s.trim();
        int high = s.length() - 1;
        int count = 0;
        while(!Character.isLetterOrDigit(s.charAt(high))){
             high--;
        }
        
        while(high >= 0){
            if(!Character.isLetterOrDigit(s.charAt(high))){
                return count;
            }
            count++;
            high--;
        }
        return count;
    }
}

