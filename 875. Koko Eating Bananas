class Solution {
    public int minEatingSpeed(int[] piles, int h) {
       

       int max = piles[0];

        for(int pile : piles){
            max = Math.max(max, pile);
        }

        int low = 1;
        int high = max;
      

        while(low < high){
            
            int mid = low + (high - low) / 2;
            int hours = 0;
            for(int piled : piles){
                hours += (piled + mid - 1) / mid;
            }
            if(hours <= h){
                high = mid;
            }else{
                low = mid + 1;
            }
            
        }
        return low;
    }
}
