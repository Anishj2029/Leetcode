class Solution {
    public String reverseVowels(String s) {
        int low = 0;
        int high = s.length() - 1;
        char[] arr = s.toCharArray();

        while (low < high) {

            while (low < high && !isVowel(arr[low])) {
                low++;
            }

            while (low < high && !isVowel(arr[high])) {
                high--;
            }

            char temp = arr[low];
            arr[low] = arr[high];
            arr[high] = temp;

            low++;
            high--;
        }

        return new String(arr);
    }

    public boolean isVowel(char c) {
        return c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u'
            || c == 'A' || c == 'E' || c == 'I' || c == 'O' || c == 'U';
    }
}
