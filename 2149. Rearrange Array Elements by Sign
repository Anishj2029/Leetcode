class Solution {
public:
    vector<int> rearrangeArray(vector<int>& nums) {
        int n = nums.size();
    vector<int> sorted(n);
    int k = 0;
    int j = n / 2;
    
    for(int i = 0; i < n; i++){
        if( nums[i] >= 0){
             sorted[k] = nums[i];
             k++;
        }else if ( nums[i] < 0){
            sorted[j] = nums[i];
            j++;
        }
    }
    k = 1;
    j = n / 2;
    nums[0] =sorted[0];
    
    for(int i = 1; i < n ; i++){
        if(i % 2 == 0){
            nums[i] = sorted[k];
            k++;
        }else{
            nums[i] = sorted[j];
            j++;
        }
        
    } 
    return {nums};
    }
};
