class Solution {
public:
    int reverse(int x) {
        if (x == INT_MIN) {
            return 0; 
        }

        long reverse_val = 0; 
        int sign = 1;

        if (x < 0) {
            sign = -1;
            x = -x; 
        }    

        while (x > 0) {
            int last_digit = x % 10;
            x = x / 10;
            reverse_val = (reverse_val * 10) + last_digit; 

            
            if (reverse_val > INT_MAX) {
                return 0;
            }
        }
        
        reverse_val *= sign; 
        if (reverse_val > INT_MAX || reverse_val < INT_MIN) {
            return 0;
        }

        return (int)reverse_val;
    }
};
