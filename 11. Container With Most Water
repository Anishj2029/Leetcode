class Solution {
    public int maxArea(int[] height) {
        
        int sum = 0;
        int max = -9999;
        int i = 0;
        int j = height.length - 1;

        while(i < j){
            
            int mini = Math.min(height[i], height[j]);
            int diff = j - i;
            sum = mini * diff;
            if(max < sum){
                max = sum;
            }
            if(height[i] < height[j]){
                i++;
            }
           else{
                j--;
           }
            
        }
        return max;
    }
}
