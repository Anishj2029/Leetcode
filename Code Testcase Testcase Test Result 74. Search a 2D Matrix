class Solution {
    public boolean searchMatrix(int[][] matrix, int target) {

        for(int i = 0; i < matrix.length ;i++){
            int j = matrix[0].length - 1;
            if(matrix[i][j] >= target){
                if(matrix[i][j] == target){
                    return true;
                }
                int p;
                if(i == 0){
                    p = 0;
                }else{
                    p  = i;
                }
                
                int high = matrix[0].length - 1  ;
                int low = 0;

                while(low <= high){
                    int mid = (low + high) / 2;

                    if(matrix[p][mid] == target){
                        return true;
                    }    
                    else if(matrix[p][mid] < target){
                        low = mid + 1;
                    }
                    else{
                        high = mid - 1;
                    }
                }
            }
           
        }
        return false;
    }
}
