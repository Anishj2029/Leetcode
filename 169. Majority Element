class Solution {
    public int majorityElement(int[] nums) {
        int n = nums.length;
        HashMap<Integer, Integer> map = new HashMap<>();
        int nume = nums[0];

        for(int num : nums){
            if(map.containsKey(num)){
                map.put(num, map.get(num) + 1);
                if(map.get(num) > n /2){
                    return num;
                }
            }else{
                map.put(num, 1);
            }
        }
        return nume;
    }
}
