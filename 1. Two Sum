class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int, int> mp;
        int n = nums.size();

        for(int i = 0; i < n; i++){
            mp.insert({nums[i], i});
        }

        for(int i = 0; i < n; i++){
            int sum = target - nums[i];
             if(auto it = mp.find(sum);it != mp.end()  && it->second != i){
                return {i, it->second};
            }
        }

        
        

        
        return {};
    }
};
